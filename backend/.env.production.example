
# ===============================
# Production Environment Variables
# ===============================

# Server
PORT=5000
JWT_KEY=your_strong_production_jwt_secret

# Database
# Use a managed MongoDB service (Atlas / self-hosted)
DB_URL=mongodb+srv://<username>:<password>@<cluster-url>/ces?retryWrites=true&w=majority

# Frontend (production domain)
FRONTEND_URL=https://your-frontend-domain.com

# Cloudinary (Production Account)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# App / Security
RANDOM_CODE=your_secure_random_or_jwt_seed

# Email (Resend – Production)
RESEND_API_KEY=your_resend_production_api_key
MAIL_SEND_FROM=Example_Engineering_Society